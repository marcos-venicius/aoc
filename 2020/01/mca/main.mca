#!/usr/local/bin/mca

if argc() != 2 {
  println('usage: ', argv(0), ' <input file>')
  exit(1)
}

core   = import('core.mca')
parser = import('parser.mca')

data = parser.parse(read_entire_file(argv(1)))

part_one = core.part_one(data, 2020)

println('P1: ', part_one)

part_two = core.part_two(data, 2020)

println('P2: ', part_two)
