#!/usr/local/bin/mca

const io     = import('io')
const string = import('string')
const parser = import('./parser.mca')


const lines = map(filter(string.split(io.read_entire_file('./input.txt'), '\n'), \(line) -> line != ''), parser.parse_line)


lit_lights = brightness = 0

m1 = []
m2 = []

# @MCA allow initializing arrays with predefined size
for _ : 1000 {
  r1 = []
  r2 = []

  for _ : 1000 {
    append(r1, 0)
    append(r2, 0)
  }

  append(m1, r1)
  append(m2, r2)
}

println('finished matrix initialization...')
println('starting computation...')

start = millisecond()

# @MCA this is reeeeeeeaaaaalllyyy slow. It takes about 52 seconds to run. Improve it somehow. NOWW!
for _, line : lines {
  for r : [line.from.y, line.to.y + 1] {
    row1 = m1[r]
    row2 = m2[r]

    for c : [line.from.x, line.to.x + 1] {
      # part one
      curr1 = row1[c]

      if line.action == parser.TOGGLE_LIGHT {
        row1[c] = as_int(!curr1)
        lit_lights += if (curr1 == 0) 1 else -1
      } elif line.action == parser.TURN_LIGHT_ON {
        row1[c] = 1
        if curr1 == 0  lit_lights += 1
      } elif line.action == parser.TURN_LIGHT_OFF {
        row1[c] = 0
        if curr1 == 1  lit_lights -= 1
      }

      # part two
      curr2 = row2[c]
      if line.action == parser.TOGGLE_LIGHT {
        row2[c] = curr2 + 2
        brightness += 2
      } elif line.action == parser.TURN_LIGHT_ON {
        row2[c] curr2 + 1
        brightness += 1
      } elif line.action == parser.TURN_LIGHT_OFF {
        v = row2[c] - 1

        row2[c] = max(v, 0)

        if (brightness > 0 and v >= 0) brightness -= 1
      }
    }
  }
}

delta_seconds = (millisecond() - start) / 1000


println('P1:', lit_lights)
println('P2:', brightness)

print('took ', delta_seconds, 's to run\n')

